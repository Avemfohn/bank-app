{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Django",
      "type": "shell",
      "command": "python manage.py runserver 0.0.0.0:8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "presentation": {
        "group": "servers",
        "panel": "split"
      }
    },
    {
      "label": "Run Next.js",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "presentation": {
        "group": "servers",
        "panel": "split"
      }
    },
    {
      "label": "🚀 Start All Servers",
      "dependsOn": ["Run Django", "Run Next.js"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}